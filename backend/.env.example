# === SolVoteX Backend — Environment Variables ===

# Server
PORT=5000

# MongoDB (use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/solvotex?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-strong-random-secret-here

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com

# CORS — comma-separated frontend origins
# Example: https://your-site.wal.app,https://infinity.wal.app
ALLOWED_ORIGINS=http://localhost:3000

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Frontend URL (for email links)
APP_URL=https://your-site.wal.app
